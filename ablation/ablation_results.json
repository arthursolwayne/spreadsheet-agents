{
  "title": "GPT-5.4 Prompt Ablation on 45 Skill-Contaminated Tasks",
  "description": "These 45 tasks were identified as having VBA/formula/text contamination when GPT-5.4 was run with a bare prompt and the Codex spreadsheets skill active. The skill was then disabled and progressive prompt constraints were tested.",
  "methodology": "Each ablation stage tested a progressively more constrained prompt. The strict stage only ran on the 21 tasks that still failed after xlsx and openpyxl hints, since those had already proven sufficient for the other tasks.",
  "stages": [
    {
      "stage": 1,
      "name": "bare_skill_active",
      "result": "0/45 = 0.0%",
      "note": "All 45 tasks failed due to VBA macros, Excel formulas, or explanatory text in cells. Codex spreadsheets skill was active but had null effect."
    },
    {
      "stage": 2,
      "name": "bare_skill_disabled",
      "result": "8/45 = 17.8%",
      "note": "Disabling the skill recovered 8 tasks. Still heavy VBA/formula contamination."
    },
    {
      "stage": 3,
      "name": "xlsx_hint",
      "result": "20/45 = 44.4%",
      "note": "Generic 'manipulate xlsx directly' hint. Biggest single-step improvement."
    },
    {
      "stage": 4,
      "name": "openpyxl_hint",
      "result": "15/44 = 34.1%",
      "note": "Specific library hint performed slightly worse than generic xlsx hint (34.1% vs 44.4%). Models don't need library-specific instructions."
    },
    {
      "stage": 5,
      "name": "strict",
      "result": "8/21 = 38.1%",
      "note": "On remaining 21 failures, strict 'no VBA' prompt recovered 8 more. 16/21 hardest failures still wrote VBA/text."
    }
  ],
  "reference_models_same_45": {
    "opus_bare": "36/45 = 80.0%",
    "tetra": "43/45 = 95.6%"
  },
